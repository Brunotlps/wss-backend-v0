# ================================================
# Staging Environment — .env.staging
# ================================================
# Copy this file to .env.staging on the server and fill in the values.
# Uses Stripe TEST keys — staging never touches real money.

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=False
ALLOWED_HOSTS=staging.api.nousflow.com.br,localhost
DJANGO_SETTINGS_MODULE=config.settings.production
ENVIRONMENT=staging

# Database (staging-isolated — separate from production)
POSTGRES_DB=wss_staging
POSTGRES_USER=wss_staging
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://wss_staging:change-me@db:5432/wss_staging

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Stripe — TEST keys only (never use live keys in staging)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# CORS — staging frontend domain
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Sentry
SENTRY_DSN=

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Superuser (created on first boot)
DJANGO_SUPERUSER_EMAIL=admin@staging.nousflow.com.br
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=change-me
