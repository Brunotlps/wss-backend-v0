{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(flake8:*)",
      "Bash(black --check:*)",
      "Bash(black --diff:*)",
      "Bash(isort --check:*)",
      "Bash(isort --diff:*)",
      "Bash(pylint:*)",
      "Bash(pytest:*)",
      "Bash(coverage:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(sudo:*)"
    ]
  }
}
